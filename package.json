{
  "name": "agent-email-suite",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source email connectivity for AI agents — MCP server for OpenClaw, Claude Code, Gemini CLI, and more",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
