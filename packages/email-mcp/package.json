{
  "name": "@usejunior/email-mcp",
  "version": "0.1.0",
  "description": "MCP server adapter + CLI + watcher for agent-email",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-email": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@usejunior/email-core": "^0.1.0",
    "@usejunior/provider-microsoft": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0"
}
