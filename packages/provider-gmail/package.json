{
  "name": "@usejunior/provider-gmail",
  "version": "0.1.0",
  "description": "Gmail API email provider for agent-email",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@googleapis/gmail": "^4.0.0",
    "@usejunior/email-core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0"
}
